{
  "name": "ambo-portal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:web": "turbo run dev --filter=@ambo/web",
    "dev:mobile": "turbo run dev --filter=@ambo/mobile",
    "build:web": "turbo run build --filter=@ambo/web",
    "build:mobile": "npm run build:prod --prefix apps/mobile",
    "build:mobile:dev": "npm run build:dev --prefix apps/mobile",
    "build:mobile:preview": "npm run build:preview --prefix apps/mobile"
  },
  "devDependencies": {
    "eas-cli": "^18.0.6",
    "turbo": "^2.5.0"
  },
  "packageManager": "npm@10.2.0"
}
